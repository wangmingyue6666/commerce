{
  "name": "ecommerce-backend",
  "version": "1.0.0",
  "description": "电商商城后端API",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon --exec ts-node --transpileOnly src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "migrate": "ts-node --transpileOnly src/database/migrate.ts",
    "seed": "ts-node --transpileOnly src/database/seed.ts"
  },
  "keywords": [
    "ecommerce",
    "express",
    "typescript",
    "mysql"
  ],
  "author": "ClawShop",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.0",
    "sequelize": "^6.32.1",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.10.0",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.3",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.4.5",
    "@typescript-eslint/eslint-plugin": "^6.2.0",
    "@typescript-eslint/parser": "^6.2.0",
    "eslint": "^8.45.0",
    "jest": "^29.6.1",
    "nodemon": "^3.0.1",
    "sequelize-cli": "^6.6.5",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  }
}
